@page "/signup"
@rendermode InteractiveServer  
@* <= make this page interactive so @onclick works *@
@using ApiContracts.Users
@using Microsoft.AspNetCore.Components.Authorization
@inject NavigationManager Nav
@inject BlazorApp.Services.Interfaces.IUserService UserService

<div class="auth-panel card">
  <div class="card-body auth-body">
    <div class="auth-header mb-4">
      <div>
        <div class="small text-muted">Create your free</div>
        <h3 class="mb-1">Threadly account</h3>
        <div class="text-muted">Join the community and start sharing meaningful conversations.</div>
      </div>
      <div class="auth-icon">✨</div>
    </div>

    <div class="mb-3">
      <label class="form-label">Username</label>
      <input class="form-control" @bind="userName" />
    </div>

    <div class="mb-3">
      <label class="form-label">Password</label>
      <input class="form-control" type="password" @bind="password" />
    </div>

    <div class="mb-3">
      <label class="form-label">Confirm Password</label>
      <input class="form-control" type="password" @bind="confirm" />
    </div>

    @if (!string.IsNullOrWhiteSpace(error))
    {
      <div class="alert alert-gradient alert-danger" role="alert">@error</div>
    }

    @if (!string.IsNullOrWhiteSpace(success))
    {
      <div class="alert alert-gradient alert-success" role="alert">@success</div>
    }

    <div class="d-flex flex-wrap gap-2">
      <button class="btn btn-gradient" @onclick="HandleSignup" disabled="@isBusy">@(isBusy ? "Creating account..." : "Create account")</button>
      <button class="btn btn-soft" @onclick="GoLogin">Back to Login</button>
    </div>

    <div class="mt-4 small text-muted">Already have an account? Use the login page to access Threadly.</div>
  </div>
</div>

@code {
  private string userName = string.Empty;
  private string password = string.Empty;
  private string confirm = string.Empty;
  private bool isBusy = false;
  private string? error;
  private string? success;

  private async Task HandleSignup()
  {
    if (isBusy) return;
    error = null;

    if (string.IsNullOrWhiteSpace(userName) || string.IsNullOrWhiteSpace(password))
    {
      error = "Please provide both username and password.";
      return;
    }
    if (!string.Equals(password, confirm))
    {
      error = "Passwords do not match.";
      return;
    }

    try
    {
      isBusy = true;

      // Uses your IUserService API contract
      var create = new CreateUserDto
      {
        UserName = userName,
        Password = password
      };

      UserDto created = await UserService.AddUserAsync(create);
      success = "Your Threadly account is ready. Please log in to continue.";
      userName = string.Empty;
      password = string.Empty;
      confirm = string.Empty;
    }
    catch (Exception ex)
    {
      error = ex.Message;
    }
    finally
    {
      isBusy = false;
    }
  }

  private void GoLogin() => Nav.NavigateTo("/login"); // <-- clean navigate handler
}
