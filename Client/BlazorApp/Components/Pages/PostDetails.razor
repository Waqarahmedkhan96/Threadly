@page "/posts/{id:int}"
@using ApiContracts.Posts
@using ApiContracts.Users
@using ApiContracts.Comments
@using System.IO
@inject BlazorApp.Services.Interfaces.IPostService PostSvc
@inject BlazorApp.Services.Interfaces.IUserService UserSvc
@inject BlazorApp.Services.Interfaces.ICommentService CommentSvc
@inject AuthenticationStateProvider AuthProvider
@inject NavigationManager Nav
@inject BlazorApp.Services.Auth.SimpleAuthProvider SimpleAuthProvider

@if (!string.IsNullOrWhiteSpace(error))
{
    <div class="alert alert-danger">@error</div>
}
else if (post is null)
{
    <div class="alert alert-secondary">Loading post…</div>
}
else
{
    <div class="d-flex flex-column flex-md-row align-items-start align-items-md-center justify-content-between gap-3 mb-4">
        <div>
            <h2 class="mb-1">@post.Title</h2>
            <div class="text-muted">Posted by @authorName</div>
        </div>
        <div class="d-flex flex-wrap gap-2">
            <button class="btn btn-soft btn-sm" @onclick="GoBack">← Back</button>
            <button class="btn btn-gradient btn-sm" @onclick="ToggleLike" disabled="@(currentUserId <= 0)">
                @(isLiked ? "💔 Unlike" : "👍 Like") (@likeCount)
            </button>
        </div>
    </div>

    <div class="post-card mb-4">
        <div class="card-body">
            <div class="post-body">@post.Body</div>

            @if (post.Media?.Count > 0)
{
    <div class="mt-4 d-flex flex-wrap gap-3">
        @foreach (var media in post.Media)
        {
            @if (IsImage(media))
            {
                <img src="@media.Url" alt="Post image" class="img-fluid rounded shadow-sm" style="max-height: 320px; width: auto;" />
            }
            else if (IsVideo(media))
            {
                <video controls class="w-100 rounded shadow-sm" style="max-height: 360px;">
                    <source src="@media.Url" />
                    Your browser does not support the video tag.
                </video>
            }
            else
            {
                <div class="border rounded p-3 text-muted">Unsupported media format</div>
            }
        }
    </div>
}
        </div>
    </div>

    <div class="row gx-4">
        <div class="col-lg-7">
            <div class="card mb-4">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-center mb-3">
                        <h5 class="card-title mb-0">Comments (@(comments?.Count ?? 0))</h5>
                        <span class="badge badge-soft">Read only</span>
                    </div>

                    @if (comments is null || comments.Count == 0)
                    {
                        <div class="text-muted">No comments yet.</div>
                    }
                    else
                    {
                        foreach (var c in comments)
                        {
                            <div class="comment-card mb-3 p-3 rounded border">
                                <div class="d-flex justify-content-between align-items-center mb-2">
                                    <div class="small text-muted">by @NameFor(c.AuthorUserId)</div>
                                </div>
                                <div>@c.Body</div>
                            </div>
                        }
                    }
                </div>
            </div>
        </div>

        <div class="col-lg-5">
            <div class="card mb-4">
                <div class="card-body">
                    <h5 class="card-title">Add a comment</h5>

                    @if (currentUserId <= 0)
                    {
                        <div class="alert alert-info py-2 mb-3 small">
                            Please log in to add a comment.
                        </div>
                    }

                    <div class="mb-3">
                        <input class="form-control" value="@(currentUserId > 0 ? $"{currentUserName} ({currentUserId})" : "Not logged in")" disabled />
                    </div>

                    <textarea class="form-control mb-3" rows="4" placeholder="Write your comment…" @bind="newComment"></textarea>
                    <button class="btn btn-gradient w-100" @onclick="AddComment" disabled="@(currentUserId <= 0 || string.IsNullOrWhiteSpace(newComment))">Post comment</button>
                </div>
            </div>
        </div>
    </div>
}

@code {
    [Parameter] public int id { get; set; }

    private PostDto? post;
    private string? authorName;
    private List<CommentDto>? comments;
    private List<UserDto> users = new();
    private string newComment = "";
    private string? error;

    private int currentUserId;
    private string currentUserName = "Unknown";
    private bool isLiked;
    private int likeCount;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var auth = await AuthProvider.GetAuthenticationStateAsync();
            currentUserId = int.TryParse(auth.User.FindFirst("Id")?.Value, out var idc) ? idc : 0;
            currentUserName = auth.User.Identity?.Name ?? "Unknown";

            post = await PostSvc.GetPostByIdAsync(id, currentUserId);
            users = await UserSvc.GetAllUsersAsync();
            authorName = users.FirstOrDefault(u => u.Id == post!.AuthorUserId)?.UserName ?? "Unknown";
            comments = await CommentSvc.GetCommentsByPostIdAsync(id);

            likeCount = post.LikeCount;
            isLiked = post.IsLikedByCurrentUser;
        }
        catch (Exception ex)
        {
            error = ex.Message;
        }
    }

private static bool IsImage(PostMediaDto? media)
{
    if (media is null) return false;

    var type = media.MediaType?.Trim().ToLowerInvariant();
    if (type == "image" || (type?.StartsWith("image/") ?? false))
        return true;

    var ext = Path.GetExtension(media.Url ?? string.Empty).ToLowerInvariant();
    return ext is ".jpg" or ".jpeg" or ".png" or ".gif" or ".webp" or ".bmp" or ".svg";
}

private static bool IsVideo(PostMediaDto? media)
{
    if (media is null) return false;

    var type = media.MediaType?.Trim().ToLowerInvariant();
    if (type == "video" || (type?.StartsWith("video/") ?? false))
        return true;

    var ext = Path.GetExtension(media.Url ?? string.Empty).ToLowerInvariant();
    return ext is ".mp4" or ".webm" or ".ogg" or ".mov";
}
    private async Task AddComment()
    {
        error = null;

        if (currentUserId <= 0)
        {
            error = "Please log in to your account to add a comment.";
            return;
        }

        if (string.IsNullOrWhiteSpace(newComment)) return;

        try
        {
            await CommentSvc.CreateCommentAsync(id, new CreateCommentDto
            {
                PostId = id,
                AuthorUserId = currentUserId,
                Body = newComment
            });

            newComment = "";
            comments = await CommentSvc.GetCommentsByPostIdAsync(id);
        }
        catch (Exception ex)
        {
            error = ex.Message;
        }
    }

    private string NameFor(int userId) => users.FirstOrDefault(u => u.Id == userId)?.UserName ?? "Unknown";

    private async Task ToggleLike()
    {
        error = null;

        if (currentUserId <= 0)
        {
            error = "Please log in to your account to like this post.";
            return;
        }

        try
        {
            var status = await PostSvc.ToggleLikeAsync(id, currentUserId);
            likeCount = status.LikeCount;
            isLiked = status.IsLiked;
        }
        catch (Exception ex)
        {
            error = ex.Message;
        }
    }

    private void GoBack() => Nav.NavigateTo("/posts");
}

