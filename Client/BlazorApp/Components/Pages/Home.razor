@page "/"
@using ApiContracts.Posts
@using ApiContracts.Users
@using ApiContracts.Comments
@inject BlazorApp.Services.Interfaces.IPostService PostSvc
@inject BlazorApp.Services.Interfaces.IUserService UserSvc
@inject BlazorApp.Services.Interfaces.ICommentService CommentSvc
@inject AuthenticationStateProvider AuthProvider

<div class="feed-header mb-4">
  <div>
    <div class="small text-uppercase text-muted mb-2">Welcome back to Threadly</div>
    <h4 class="page-title mb-1">Your social feed, refreshed.</h4>
    <p class="text-muted mb-0">A personalized stream of community posts, discussions, and trending moments.</p>
  </div>
</div>

<div class="row gx-4 align-items-end mb-4 feed-toolbar">
  <div class="col-lg-8">
    <div class="input-group search-group">
      <span class="input-group-text">🔎</span>
      <input class="form-control" placeholder="Search Threadly posts, users, or tags..." @bind="searchText" @bind:event="oninput" />
    </div>
  </div>
  <div class="col-lg-4 text-lg-end mt-3 mt-lg-0">
    <select class="form-select brand-select" @bind="sortMode">
      <option value="hot">Hot</option>
      <option value="new">New</option>
    </select>
  </div>
</div>

@if (loading)
{
  <Loading />
}
else if (items is null || items.Count == 0)
{
  <div class="alert alert-light border">No posts yet — be the first to share something!</div>
}
else
{
  var viewItems = FilteredItems.ToList();

  if (viewItems.Count == 0)
  {
    <div class="alert alert-light border">No posts match your search.</div>
  }
  else
  {
    @foreach (var item in viewItems)
    {
      <BlazorApp.Components.PostCard
          Post="item.Post"
          Preview="item.Preview"
          FullBody="item.FullBody"
          CommentCount="item.CommentCount"
          IsLoggedIn="isLoggedIn" />
    }
  }
}

@code {
  private bool loading;
  private bool isLoggedIn;

  // search text
  private string? searchText;

  // Use a backing field so we can react when the user changes the dropdown
  private string _sortMode = "hot";
  private string sortMode
  {
    get => _sortMode;
    set
    {
      if (_sortMode == value) return;
      _sortMode = value;
      if (items is not null) items = ApplySort(items);
      StateHasChanged();
    }
  }

  private List<FeedItem>? items;

  private class FeedItem
  {
    public required PostSummaryDto Post { get; set; }
    public required string Preview { get; set; }
    public required string FullBody { get; set; }
    public int CommentCount { get; set; }
    public int AuthorUserId { get; set; }
  }

  protected override async Task OnInitializedAsync()
  {
    var auth = await AuthProvider.GetAuthenticationStateAsync();
    isLoggedIn = auth.User.Identity?.IsAuthenticated ?? false;
    await Load();
  }

  private async Task Load()
  {
    loading = true;
    try
    {
      var summaries = await PostSvc.GetPostsAsync(new PostQueryParameters { TitleContains = null });

      var users = await UserSvc.GetAllUsersAsync();
      var usersById = users.ToDictionary(u => u.Id, u => u.UserName);

      Dictionary<int,int> counts;
      try
      {
        var allComments = await CommentSvc.GetAllCommentsAsync();
        counts = allComments.GroupBy(c => c.PostId).ToDictionary(g => g.Key, g => g.Count());
      }
      catch
      {
        counts = new Dictionary<int,int>();
      }

      var list = new List<FeedItem>();
      foreach (var s in summaries)
      {
        var full = await PostSvc.GetPostByIdAsync(s.Id);

        s.AuthorName = usersById.TryGetValue(full.AuthorUserId, out var nm) ? nm : null;

        var body = (full.Body ?? string.Empty).Trim();
        body = body.Replace("\r\n", " ").Replace("\n", " ").Replace("\r", " ");
        var preview = body.Length > 450 ? body[..450] + "…" : (string.IsNullOrWhiteSpace(body) ? "(no body)" : body);

        list.Add(new FeedItem
        {
          Post = s,
          Preview = preview,
          FullBody = body,
          CommentCount = counts.TryGetValue(s.Id, out var n) ? n : 0,
          AuthorUserId = full.AuthorUserId
        });
      }

      items = ApplySort(list);
    }
    finally { loading = false; }
  }

  private IEnumerable<FeedItem> FilteredItems => ApplyFilter(items ?? new List<FeedItem>());

  private IEnumerable<FeedItem> ApplyFilter(IEnumerable<FeedItem> source)
  {
    if (string.IsNullOrWhiteSpace(searchText))
      return source;

    var term = searchText.Trim();
    var isNumber = int.TryParse(term, out var number);

    return source.Where(i =>
        (isNumber && i.Post.Id == number)
        || (isNumber && i.AuthorUserId == number)
        || (!string.IsNullOrEmpty(i.Post.Title) && i.Post.Title.Contains(term, StringComparison.OrdinalIgnoreCase))
        || (!string.IsNullOrEmpty(i.Preview) && i.Preview.Contains(term, StringComparison.OrdinalIgnoreCase))
        || (!string.IsNullOrEmpty(i.Post.AuthorName) && i.Post.AuthorName.Contains(term, StringComparison.OrdinalIgnoreCase))
    );
  }

  private List<FeedItem> ApplySort(IEnumerable<FeedItem> source)
  {
    return sortMode switch
    {
      "new" => source.OrderByDescending(i => i.Post.Id).ToList(),
      "hot" or _ => source.OrderByDescending(i => i.CommentCount)
                          .ThenByDescending(i => i.Post.Id)
                          .ToList(),
    };
  }
}
