@using ApiContracts.Posts
@using ApiContracts.Comments
@inject BlazorApp.Services.Interfaces.ICommentService CommentSvc
@inject BlazorApp.Services.Interfaces.IPostService PostSvc
@inject BlazorApp.Services.Auth.SimpleAuthProvider SimpleAuthProvider

<div class="post-card-modern">
  <div class="post-card-container">
    <div class="post-header">
      <div class="d-flex gap-3 align-items-start">
        <div class="profile-avatar">
          @GetInitials(Post.AuthorName)
        </div>
        <div class="profile-meta">
          <div class="username">
            @((string.IsNullOrWhiteSpace(Post.AuthorName) ? "Unknown" : Post.AuthorName))
            <span class="post-time">4h ago</span>
          </div>
          <div class="text-muted small">Post #@Post.Id · Community update</div>
        </div>
      </div>

      <div class="post-actions">
        <button class="btn btn-sm btn-gradient action-pill" @onclick="HandleFollow">@followLabel</button>
        <button class="icon-button" @onclick="ToggleMenu">⋯</button>
      </div>
    </div>

    <div>
      <a class="post-title-link" href="/posts/@Post.Id">@Post.Title</a>
      <p class="post-copy @(expanded ? string.Empty : "collapsed")">@DisplayedBody</p>
      @if (NeedsSeeMore)
      {
        <button class="see-more" @onclick="ToggleExpanded">@(expanded ? "Show less" : "See more")</button>
      }
    </div>

    @if (Media?.Count > 0)
    {
      <div class="post-media">
        @foreach (var media in Media)
        {
          @if (IsImage(media))
          {
            <img src="@media.Url" alt="Uploaded image" class="post-media-image" />
          }
          else if (IsVideo(media))
          {
            <video controls class="post-media-video">
              <source src="@media.Url" />
              Your browser does not support the video tag.
            </video>
          }
          else
          {
            <div class="media-placeholder">Unsupported media format</div>
          }
        }
      </div>
    }
    else
    {
      <div class="post-media">
        <div class="media-placeholder">No media attached</div>
      </div>
    }

    <div class="interaction-bar">
      <div class="interaction-actions">
        <button class="btn btn-outline-primary action-pill @(IsLoggedIn ? string.Empty : "disabled")" @onclick="HandleLike">@(IsLiked ? "👍 Unlike" : "👍 Like")</button>
        <button class="btn btn-outline-primary action-pill @(IsLoggedIn ? string.Empty : "disabled")" @onclick="ToggleComments">💬 Comment</button>
        <button class="btn btn-outline-primary action-pill @(IsLoggedIn ? string.Empty : "disabled")" @onclick="ToggleShare">🔄 Share</button>
      </div>

      <div class="interaction-summary">
        <span>❤️ @likeCount</span>
        <span>💬 @CommentCount</span>
        <span>🔁 @shareCount</span>
      </div>
    </div>

    @if (showLoginPrompt)
    {
      <div class="login-prompt text-muted">
        Sign in to like, comment, or share this post.
      </div>
    }

    @if (likesPopup)
    {
      <div class="menu-panel mt-2">
        <div class="text-muted small mb-2">Liked by</div>
        <div class="d-flex flex-wrap gap-2">
          @foreach (var name in likeNames)
          {
            <span class="badge badge-soft">@name</span>
          }
        </div>
      </div>
    }

    @if (shareOpen)
    {
      <div class="share-panel mt-2">
        <div class="d-flex flex-column gap-2">
          <button class="btn btn-sm btn-gradient">Share to Threadly</button>
          <button class="btn btn-sm btn-soft">Copy link</button>
        </div>
        <div class="text-muted small mt-3">Shared by @shareCount people</div>
      </div>
    }

    @if (commentsOpen)
    {
      <div class="comments-panel mt-2">
        @if (commentsLoading)
        {
          <div class="text-muted">Loading comments…</div>
        }
        else if (comments.Count == 0)
        {
          <div class="text-muted">No comments yet. Be the first to join the conversation.</div>
        }
        else
        {
          @foreach (var comment in comments)
          {
            <div class="comment-row">
              <div class="comment-meta">
                <span class="comment-author">@(string.IsNullOrWhiteSpace(comment.AuthorName) ? $"User {comment.AuthorUserId}" : comment.AuthorName)</span>
                <span>@comment.CreatedAt.ToString("dd MMM")</span>
              </div>
              <div class="comment-body">@comment.Body</div>
            </div>
          }
        }
      </div>
    }
  </div>
</div>

@code {
  [Parameter] public required PostSummaryDto Post { get; set; }
  [Parameter] public required string Preview { get; set; }
  [Parameter] public required string FullBody { get; set; }
  [Parameter] public int CommentCount { get; set; }
  [Parameter] public int LikeCount { get; set; }
  [Parameter] public bool IsLiked { get; set; }
  [Parameter] public List<PostMediaDto> Media { get; set; } = new();
  [Parameter] public bool IsLoggedIn { get; set; }

  private bool expanded;
  private bool followState;
  private bool likesPopup;
  private bool commentsOpen;
  private bool shareOpen;
  private bool showLoginPrompt;
  private bool commentsLoading;

  private int likeCount;
  private int shareCount;

  private List<CommentDto> comments = new();
  private readonly string[] likeNames = new[] { "Avery", "Jordan", "Mia", "Noah", "Kai" };

  private string SafePreview => string.IsNullOrWhiteSpace(Preview) ? string.Empty : Preview;
  private string SafeFullBody => string.IsNullOrWhiteSpace(FullBody) ? string.Empty : FullBody;
  private string DisplayedBody => expanded ? SafeFullBody : SafePreview;

  private bool NeedsSeeMore =>
      !string.IsNullOrWhiteSpace(SafeFullBody)
      && !string.Equals(SafePreview, SafeFullBody, StringComparison.Ordinal)
      && SafeFullBody.Length > SafePreview.Length;

  private string followLabel => followState ? "Following" : "Follow";

  protected override void OnInitialized()
  {
    likeCount = Math.Max(0, LikeCount);
    shareCount = Math.Max(3, CommentCount / 2 + 2);
  }

  private void HandleFollow()
  {
    if (!IsLoggedIn)
    {
      showLoginPrompt = true;
      return;
    }

    followState = !followState;
    showLoginPrompt = false;
  }

  private async Task HandleLike()
  {
    if (!IsLoggedIn)
    {
      showLoginPrompt = true;
      likesPopup = false;
      return;
    }

    var currentUser = SimpleAuthProvider.GetCurrentUserDtoOrNull();
    if (currentUser is null)
    {
      showLoginPrompt = true;
      return;
    }

    showLoginPrompt = false;
    try
    {
      var status = await PostSvc.ToggleLikeAsync(Post.Id, currentUser.Id);
      likeCount = status.LikeCount;
      IsLiked = status.IsLiked;
    }
    catch
    {
    }
  }

  private async Task ToggleComments()
  {
    if (!IsLoggedIn)
    {
      showLoginPrompt = true;
      return;
    }

    showLoginPrompt = false;
    commentsOpen = !commentsOpen;

    if (commentsOpen && comments.Count == 0)
    {
      await LoadComments();
    }
  }

  private void ToggleShare()
  {
    if (!IsLoggedIn)
    {
      showLoginPrompt = true;
      return;
    }

    showLoginPrompt = false;
    shareOpen = !shareOpen;
    if (shareOpen)
    {
      shareCount += 1;
    }
  }

  private void ToggleMenu()
  {
    likesPopup = false;
    shareOpen = false;
    commentsOpen = false;
    showLoginPrompt = false;
  }

  private void ToggleExpanded()
  {
    expanded = !expanded;
  }

  private async Task LoadComments()
  {
    commentsLoading = true;
    try
    {
      comments = await CommentSvc.GetCommentsByPostIdAsync(Post.Id);
    }
    catch
    {
      comments = new List<CommentDto>();
    }
    finally
    {
      commentsLoading = false;
    }
  }

  private static bool IsImage(PostMediaDto? media)
  {
    if (media is null) return false;

    var type = media.MediaType?.Trim().ToLowerInvariant();
    if (type == "image" || (type?.StartsWith("image/") ?? false))
        return true;

    var ext = Path.GetExtension(media.Url ?? string.Empty).ToLowerInvariant();
    return ext is ".jpg" or ".jpeg" or ".png" or ".gif" or ".webp" or ".bmp" or ".svg";
  }

  private static bool IsVideo(PostMediaDto? media)
  {
    if (media is null) return false;

    var type = media.MediaType?.Trim().ToLowerInvariant();
    if (type == "video" || (type?.StartsWith("video/") ?? false))
        return true;

    var ext = Path.GetExtension(media.Url ?? string.Empty).ToLowerInvariant();
    return ext is ".mp4" or ".webm" or ".ogg" or ".mov";
  }

  private static string GetInitials(string? name)
  {
    if (string.IsNullOrWhiteSpace(name))
      return "T";

    var parts = name.Split(' ', StringSplitOptions.RemoveEmptyEntries);
    if (parts.Length == 1)
      return parts[0].Substring(0, 1).ToUpperInvariant();

    return string.Concat(parts[0][0], parts[^1][0]).ToUpperInvariant();
  }
}